DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swades_chunks
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=recording-chunks
S3_FORCE_PATH_STYLE=true
CHUNK_UPLOAD_MAX_RETRIES=3
CHUNK_RECONCILE_BATCH_SIZE=200
NODE_ENV=development
